package lab2;
import java.util.Scanner;
public class BusluurTootsooloh  {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.print("R Райдиус метрийг оруулна уу:");
		double R = sc.nextDouble();	
		double pi = Math.PI;
		double busluur = 2 * pi * R;
		System.out.println("Бүслүүр =" + busluur + "метр");
		sc.close();
	}
}
